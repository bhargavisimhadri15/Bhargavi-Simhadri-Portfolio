PORT=5000

# MongoDB (local)
MONGODB_URI=mongodb://localhost:27017/bhargavi_portfolio

# MongoDB Atlas example (recommended: include a DB name, not just the cluster)
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/bhargavi_portfolio?retryWrites=true&w=majority&appName=Cluster0

# SMTP (email) configuration for contact form
# Example (Gmail App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your_app_password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Where you want to receive contact form emails
MAIL_TO=bhargavisimhadri1998@gmail.com

# Sender address (often must match SMTP_USER for some providers)
MAIL_FROM=

# Owner-only token for portfolio project CRUD (required for POST/PUT/DELETE /api/projects)
ADMIN_TOKEN=change_me
